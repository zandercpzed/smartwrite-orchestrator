{
  "name": "smartwrite-orchestrator",
  "version": "0.1.0",
  "description": "Hub plugin that installs and orchestrates SmartWrite modules from GitHub.",
  "author": "Zander Catta Preta",
  "license": "MIT",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": ["obsidian", "plugin", "publishing", "writing"],
  "devDependencies": {
    "@types/node": "^20.10.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.24.2",
    "tslib": "2.4.0",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "obsidian": "latest"
  }
}
