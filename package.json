{
  "name": "smartwrite-orchestrator",
  "version": "0.1.0",
  "description": "Hub plugin that installs and orchestrates SmartWrite modules from GitHub.",
  "author": "Zander Catta Preta",
  "license": "MIT",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "lint": "eslint ."
  },
  "keywords": [
    "obsidian",
    "plugin",
    "publishing",
    "writing"
  ],
  "devDependencies": {
    "@eslint/js": "9.30.1",
    "@eslint/json": "^1.2.0",
    "@types/node": "^16.11.6",
    "esbuild": "0.25.5",
    "eslint-plugin-obsidianmd": "0.1.9",
    "globals": "14.0.0",
    "jiti": "2.6.1",
    "tslib": "2.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "8.35.1"
  },
  "dependencies": {
    "obsidian": "latest"
  }
}
